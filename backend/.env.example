# Copy this file to .env and configure your database URL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/cognimap

# Google Gemini API key for LLM-powered narrative generation
GOOGLE_API_KEY=your_google_api_key_here

# Google OAuth client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Secret key for signing internal JWTs
SECRET_KEY=generate-a-random-secret-string-here
